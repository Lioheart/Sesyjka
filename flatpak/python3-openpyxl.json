    "tar -xOf openpyxl-3.1.5.tar.gz openpyxl-3.1.5/LICENCE.rst > ${FLATPAK_DEST}/share/licenses/io.github.zuraffpl.Sesyjka/openpyxl-LICENCE.rst"
  ],
