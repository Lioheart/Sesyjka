Name:           sesyjka
Version:        @VERSION@
Release:        1%{?dist}
Summary:        GTK4 application for tabletop RPG collections and sessions
License:        CC-BY-4.0
URL:            https://github.com/Lioheart/Sesyjka
Source0:        %{name}-%{version}.tar.gz
BuildArch:      noarch

Requires:       python3 >= 3.10
Requires:       python3-gobject
Requires:       gtk4
Requires:       libadwaita
Requires:       python3-openpyxl
Recommends:     polkit

%description
Sesyjka manages tabletop RPG systems, books, supplements, sessions,
players, publishers, statistics and compatible SQLite databases.

%prep
%autosetup

%build

%install
rm -rf %{buildroot}
install -d \
  %{buildroot}%{_datadir}/sesyjka \
  %{buildroot}%{_bindir} \
  %{buildroot}%{_datadir}/applications \
  %{buildroot}%{_datadir}/metainfo \
  %{buildroot}%{_datadir}/doc/%{name}
cp -a sesyjka data %{buildroot}%{_datadir}/sesyjka/
install -m 0644 LICENSE %{buildroot}%{_datadir}/doc/%{name}/LICENSE
install -m 0644 NOTICE.md %{buildroot}%{_datadir}/doc/%{name}/NOTICE.md
install -m 0644 README.md %{buildroot}%{_datadir}/doc/%{name}/README.md
install -m 0644 README.en.md %{buildroot}%{_datadir}/doc/%{name}/README.en.md

cat > %{buildroot}%{_bindir}/sesyjka <<'WRAPPER'
#!/usr/bin/env sh
export SESYJKA_INSTALL_CHANNEL="rpm"
export SESYJKA_UPDATE_REPOSITORY="Lioheart/Sesyjka"
PYTHONPATH="/usr/share/sesyjka${PYTHONPATH:+:$PYTHONPATH}" exec python3 -m sesyjka "$@"
WRAPPER
chmod 0755 %{buildroot}%{_bindir}/sesyjka
sed 's|^Exec=.*$|Exec=/usr/bin/sesyjka|' \
  data/io.github.zuraffpl.Sesyjka.desktop \
  > %{buildroot}%{_datadir}/applications/io.github.zuraffpl.Sesyjka.desktop
install -m 0644 data/io.github.zuraffpl.Sesyjka.metainfo.xml \
  %{buildroot}%{_datadir}/metainfo/io.github.zuraffpl.Sesyjka.metainfo.xml
cp -a data/icons %{buildroot}%{_datadir}/

%check
python3 -m compileall -q sesyjka
python3 -m unittest discover -s tests -v

%files
%license %{_datadir}/doc/%{name}/LICENSE
%doc %{_datadir}/doc/%{name}/NOTICE.md
%doc %{_datadir}/doc/%{name}/README.md
%doc %{_datadir}/doc/%{name}/README.en.md
%{_bindir}/sesyjka
%{_datadir}/sesyjka/
%{_datadir}/applications/io.github.zuraffpl.Sesyjka.desktop
%{_datadir}/metainfo/io.github.zuraffpl.Sesyjka.metainfo.xml
%{_datadir}/icons/hicolor/*/apps/io.github.zuraffpl.Sesyjka.*

%changelog
* Sun Jul 19 2026 Lioheart <noreply@github.com> - @VERSION@-1
- Automated GitHub Release package
